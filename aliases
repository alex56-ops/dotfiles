# Named Directories
hash -d prod=~/repos/kubernetes-config/config/production-cluster
hash -d staging=~/repos/kubernetes-config/config/staging-cluster
hash -d test=~/repos/kubernetes-config/config/test-cluster

alias prod='cd ~prod'
alias staging='cd ~staging'
alias test='cd ~test'

# Teleport Login Alias
alias teleport='tsh login --proxy=teleport.sys.mixxt.net:3080 --auth=passwordless'

# Arch Linux Installation Aliases
alias arch-install='source .env && export $(cat .env | xargs) && ansible-playbook -i setup.ini arch-baremetal-install.yml'
alias k8s-setup='ansible-playbook -i setup.ini k8s-node-setup.yml'

# Wazuh Control
alias wazuh='sudo /Library/Ossec/bin/wazuh-control'

# Colima
alias colima-log='log show --predicate '\''eventMessage contains "colima-idle-check"'\'' --last 30m'

# Podman Aliases
alias pc='podman-compose'

# Server03 Aliases
alias reset-update-timer='ssh server03 "sudo systemctl reset-failed ansible-auto-update.service"'

# Win11-DATEV VM RDP (password stored in macOS Keychain, service "win11-datev-rdp")
alias win11rdp='xfreerdp /v:172.25.20.51 /u:admin /d:. /p:"$(security find-generic-password -a admin -s win11-datev-rdp -w)"'
alias win11rdp-smartcard='xfreerdp /v:172.25.20.51 /u:admin /d:. /p:"$(security find-generic-password -a admin -s win11-datev-rdp -w)" /smartcard'

# List VMs on dev-server-ansible (plain "virsh list" defaults to qemu:///session for this user and shows nothing)
alias dev-server-vms='ssh dev-server-ansible "sudo virsh list --all"'

 #  Suffix Aliases

# Archive
alias -s {zip,ZIP}=unzip -l
alias -s {tar.gz,tgz}=tar -tzf

# Markdown
alias -s md='glow'

# Format JSON
alias -s json='jq .'
